{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc-project/refs/heads/nicolo/config-json-schema/npm/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "jsPlugins": ["./scripts/oxlint-plugin-reins.cjs"],
  "rules": {
    "no-new": "off",
    "unicorn/prefer-add-event-listener": "off",
    "unicorn/require-post-message-target-origin": "off",
    "typescript/consistent-type-assertions": ["error", { "assertionStyle": "never" }],
    "reins/no-reexports": "error",
    "reins/no-exported-type-realiases": "error"
  },
  "overrides": [
    {
      "files": ["packages/backend/src/**/*.ts"],
      "rules": {
        "no-console": "error"
      }
    },
    {
      "files": [
        "packages/backend/src/logger.ts",
        "packages/backend/src/__tests__/**/*.ts"
      ],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
